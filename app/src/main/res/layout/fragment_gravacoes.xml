<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">
    <EditText
        android:id="@+id/edtTituloGravacao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Título da gravação"
        android:inputType="text"
        android:layout_marginBottom="16dp" />
    <Button
        android:id="@+id/btnGravar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="INICIAR GRAVAÇÃO"
        android:layout_marginBottom="16dp" />
    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: parado"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />
    <TextView
        android:id="@+id/txtTituloLista"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gravações:"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerGravacoes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>